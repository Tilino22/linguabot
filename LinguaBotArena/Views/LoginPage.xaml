<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LinguaBotArena.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0A0A1A">

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="20" VerticalOptions="Center">

            <!-- Logo / Robot -->
            <Label
                Text="🤖"
                FontSize="80"
                HorizontalOptions="Center" />

            <Label
                Text="LinguaBot Arena"
                FontSize="32"
                FontAttributes="Bold"
                TextColor="#00FF88"
                HorizontalOptions="Center" />

            <Label
                Text="Aprende idiomas. Compite. Gana."
                FontSize="14"
                TextColor="#888888"
                HorizontalOptions="Center"
                Margin="0,0,0,20" />

            <!-- Username -->
            <Frame BackgroundColor="#1A1A2E" BorderColor="#00FF88" CornerRadius="10" Padding="5">
                <Entry
                    x:Name="UsernameEntry"
                    Placeholder="Usuario"
                    PlaceholderColor="#555555"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontSize="16" />
            </Frame>

            <!-- Password -->
            <Frame BackgroundColor="#1A1A2E" BorderColor="#00FF88" CornerRadius="10" Padding="5">
                <Entry
                    x:Name="PasswordEntry"
                    Placeholder="Contraseña"
                    PlaceholderColor="#555555"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontSize="16"
                    IsPassword="True" />
            </Frame>

            <!-- Error Label -->
            <Label
                x:Name="ErrorLabel"
                TextColor="#FF4444"
                FontSize="13"
                HorizontalOptions="Center"
                IsVisible="False" />

<!-- Login Button -->
<Button
    x:Name="LoginButton"
    Text="ENTRAR AL ARENA"
    BackgroundColor="#00FF88"
    TextColor="#0A0A1A"
    FontAttributes="Bold"
    FontSize="16"
    CornerRadius="10"
    HeightRequest="50"
    Clicked="LoginButton_Clicked" />

<!-- Register Button -->
<Button
    Text="¿No tienes cuenta? Regístrate"
    BackgroundColor="Transparent"
    TextColor="#00FF88"
    FontSize="14"
    Clicked="RegisterButton_Clicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>