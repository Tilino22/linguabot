<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LinguaBotArena.Views.LeaderboardPage"
             BackgroundColor="#0A0A1A"
             Title="Leaderboard">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,10,0,20">
            <Button Grid.Column="0" Text="←" BackgroundColor="Transparent"
                    TextColor="#00FF88" FontSize="24" Clicked="OnBackClicked"/>
            <Label Grid.Column="1" Text="🏆 LEADERBOARD" FontSize="22" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- Lista -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12">

                <!-- Tu posición -->
                <Border x:Name="MyRankPanel" BackgroundColor="#0D1F0D" Stroke="#00FF88"
                        StrokeThickness="2" StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12">
                        <Label Grid.Column="0" x:Name="MyRankLabel" Text="#-"
                               FontSize="20" FontAttributes="Bold" TextColor="#00FF88"
                               VerticalOptions="Center" WidthRequest="50"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label x:Name="MyUsernameLabel" Text="Tú" FontSize="16"
                                   TextColor="White" FontAttributes="Bold"/>
                            <Label x:Name="MyRankNameLabel" Text="" FontSize="12" TextColor="#888899"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" x:Name="MyXpLabel" Text="0 XP"
                               FontSize="16" FontAttributes="Bold" TextColor="#00FF88"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <BoxView HeightRequest="1" BackgroundColor="#333355" Margin="0,4"/>

                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                                   Color="#00FF88" HeightRequest="40"/>

                <!-- Lista de jugadores -->
                <VerticalStackLayout x:Name="LeaderboardStack" Spacing="8"/>

                <!-- Error -->
                <Label x:Name="ErrorLabel" TextColor="#FF4444" FontSize="14"
                       HorizontalOptions="Center" IsVisible="False"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>